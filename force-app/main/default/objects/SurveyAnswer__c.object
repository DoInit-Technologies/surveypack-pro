<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Individual answer records normalized per question</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <fields>
        <fullName>SurveyResponse__c</fullName>
        <externalId>false</externalId>
        <label>Survey Response</label>
        <referenceTo>SurveyResponse__c</referenceTo>
        <relationshipLabel>Answers</relationshipLabel>
        <relationshipName>Answers</relationshipName>
        <relationshipOrder>0</relationshipOrder>
        <required>true</required>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>SurveyQuestion__c</fullName>
        <externalId>false</externalId>
        <label>Question</label>
        <referenceTo>SurveyQuestion__c</referenceTo>
        <relationshipLabel>Answers</relationshipLabel>
        <relationshipName>Answers</relationshipName>
        <relationshipOrder>0</relationshipOrder>
        <required>true</required>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Text_Answer__c</fullName>
        <description>Text answer for text-type questions</description>
        <externalId>false</externalId>
        <label>Text Answer</label>
        <length>2000</length>
        <required>false</required>
        <type>TextArea</type>
    </fields>
    <fields>
        <fullName>Number_Answer__c</fullName>
        <description>Numeric answer for NPS or Rating type questions</description>
        <externalId>false</externalId>
        <label>Number Answer</label>
        <precision>10</precision>
        <required>false</required>
        <scale>0</scale>
        <type>Number</type>
    </fields>
    <fields>
        <fullName>Selected_Options__c</fullName>
        <description>JSON array of selected options for MultipleChoice</description>
        <externalId>false</externalId>
        <label>Selected Options</label>
        <length>500</length>
        <required>false</required>
        <type>TextArea</type>
    </fields>
    <label>Survey Answer</label>
    <nameField>
        <label>Survey Answer</label>
        <type>Text</type>
    </nameField>
    <pluralLabel>Survey Answers</pluralLabel>
    <sharingModel>ReadWrite</sharingModel>
    <visibility>Public</visibility>
</CustomObject>
